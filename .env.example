APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── ERP Logística Argentina — integraciones ──────────────────────────
# ArcaGateway (facturación electrónica AFIP/ARCA vía microservicio)
ARCA_GATEWAY_URL=http://127.0.0.1:8000
ARCA_CLIENT_ID=
ARCA_API_KEY=
ARCA_GATEWAY_TIMEOUT=60
# CUIT de la empresa representada ante AFIP (auditoría 2026-07-12 #4:
# antes estaba hardcodeado en el código). 11 dígitos sin guiones.
ARCA_CUIT_REPRESENTADO=30717060985

# Sync de facturas de compra con DistriApp (contrato v1.54)
DISTRIAPP_WEBHOOK_SECRET=
DISTRIAPP_BASE_URL=

# ── Item 8 — autorización fina (auditoría 2026-07-12) ────────────────
# Modo del gate de permisos: 'enforce' (403 sin permiso) | 'log' (solo
# observa y loguea, para rollout en prod).
ERP_PERMISOS_MODO=enforce
# Bypass del gate para super_admin. SIEMPRE true en prod; false solo en
# dev para el test de robustez de la matriz.
ERP_SUPERADMIN_BYPASS=true

# ── Base de datos del ERP (MariaDB/MySQL 8 obligatoria) ──────────────
# El default sqlite del stock de Laravel NO sirve: el esquema usa ENUMs,
# CHECKs, triggers y SPs. Local: clonar desde el dev del VPS (ver
# PLAN_REMEDIACION_ESTADO.md, tarea 2.1).
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erp_logistica_dev
DB_USERNAME=erp_dev
DB_PASSWORD=
APP_TIMEZONE=America/Argentina/Buenos_Aires
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# ── MFA / OTP (v1.15 fix MFA fresh) ───────────────────────────────────
OTP_ENABLED=true
OTP_LIFETIME=10
OTP_KEEP_ALIVE=true
OTP_THROW_EXCEPTION=false

# ── Mercado Pago (cierres diarios — parser/poll de reportes) ─────────
# ⚠️ Se leen con env() directo en McpMpClient (fuera de config/) — deuda
# anotada en PLAN_REMEDIACION_ESTADO.md 7.5.
MP_ACCESS_TOKEN=
MP_API_BASE=https://api.mercadopago.com
MP_REPORT_POLL_INTERVAL_SECONDS=5
MP_REPORT_TIMEOUT_SECONDS=120

# ── Módulo Sueldos (workstream 2026-07-13, decisiones P1-P9) ─────────
# Redondeo del efectivo hacia arriba (billetes). 0 = sin redondeo.
ERP_SUELDOS_REDONDEO_EFECTIVO=500
# Cuenta (código) de la diferencia de redondeo.
ERP_SUELDOS_CUENTA_DIF_REDONDEO=5.4.09
# Valor hora = básico / divisor. Excel: (básico/30)/8 = 240.
ERP_SUELDOS_DIVISOR_HORA=240
# Meses del semestre para el MAX del SAC (LCT: 6).
ERP_SUELDOS_SAC_MESES=6
ERP_SUELDOS_DESCUENTOS_LEGALES=false
ERP_SUELDOS_PRESENTISMO=false
